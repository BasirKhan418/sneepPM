# App
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
GATEWAY_URL=http://localhost:4000
NEXT_PUBLIC_GATEWAY_URL=http://localhost:4000

# Email/password auth and sessions
JWT_SECRET=replace-with-long-random-secret
PASSWORD_PEPPER=replace-with-long-random-pepper
CRON_SECRET=replace-with-long-random-secret

# MongoDB
MONGO_URI=mongodb://localhost:27017/zira
MONGODB_URI=mongodb://localhost:27017/zira

# Redis / Valkey
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379
VALKEY_URL=redis://localhost:6379

# SMTP / SES / Nodemailer
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=replace-with-smtp-user
EMAIL_PASSWORD=replace-with-smtp-password
EMAIL_USER_V2=team@example.com
EMAIL_FROM=Zira <team@example.com>

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=replace-with-access-key
AWS_SECRET_ACCESS_KEY=replace-with-secret-key
AWS_S3_BUCKET=replace-with-private-bucket
S3_BUCKET=replace-with-private-bucket
S3_REGION=ap-south-1
S3_UPLOAD_MAX_BYTES=209715200
S3_PRESIGN_EXPIRES_SECONDS=300

# AI / Pulse
AI_PROVIDER=openai
OPENAI_API_KEY=replace-if-using-openai
ANTHROPIC_API_KEY=replace-if-using-anthropic

# Security and retention
INVITE_TOKEN_TTL_DAYS=7
MEETING_REMINDER_MINUTES=10
PRESENCE_HEARTBEAT_SECONDS=20
PRESENCE_IDLE_SECONDS=300
RATE_LIMIT_WINDOW_SECONDS=60
RETENTION_DAYS=365